# Duplicate this file and rename to `.env`. Complete with the corresponding secrets
AUTH_FIUBA_URL=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AWS_DOMAIN_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
GOOGLE_CLIENT_ID=
BASE_URL=http://localhost:8007
FRONTEND_BASE_URL=http://localhost:8081

# Database: uncomment DATABASE_URL to connect to a remote database (e.g. Supabase Session Pooler).
# When set, DATABASE_URL takes priority over the SQL_* variables.
# For Supabase use Session Pooler (port 5432) — Transaction Pooler doesn't support prepared statements.
# DATABASE_URL=postgresql://...
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# Local file storage root for form templates/submissions.
# Default project-level path is `ludo3/data` (from backend folder: ../data).
LOCAL_STORAGE_ROOT=../data
